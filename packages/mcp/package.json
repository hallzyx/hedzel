{
  "name": "hedera-insights-mcp",
  "version": "1.0.2",
  "description": "MCP server that lets any AI agent buy Hedera on-chain intelligence over x402 — discovers the catalog, pays in HBAR, and returns verified data.",
  "type": "module",
  "license": "MIT",
  "author": "hallzyx",
  "homepage": "https://github.com/hallzyx/hedzel/tree/main/packages/mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hallzyx/hedzel.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/hallzyx/hedzel/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "hedera",
    "x402",
    "ai-agent",
    "agentic-commerce",
    "hbar",
    "on-chain"
  ],
  "bin": {
    "hedera-insights-mcp": "dist/index.cjs"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "rimraf dist && esbuild src/index.ts --bundle --platform=node --format=cjs --target=node20 --minify --outfile=dist/index.cjs",
    "start": "node dist/index.cjs",
    "config": "node dist/index.cjs config",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@hiero-ledger/sdk": "2.79.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^22.7.0",
    "esbuild": "^0.24.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.0",
    "zod": "^3.23.8"
  },
  "engines": {
    "node": ">=20"
  }
}
