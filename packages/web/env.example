# Copy to `.env.local` (cp env.example .env.local) and adjust.

# URL of the agent backend (local dev or Railway deployment).
NEXT_PUBLIC_AGENT_URL=http://localhost:3001

# Hedera network the UI targets.
NEXT_PUBLIC_HEDERA_NETWORK=testnet

# Optional: enables real HashPack / WalletConnect v2 pairing instead of the
# demo connector. Get one at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
