# Copy this file to `.env` (cp env.example .env) and fill in your values.

# --- Hedera ---
# Treasury account that receives HBAR micropayments (also the x402 payTo).
HEDERA_ACCOUNT_ID=0.0.XXXXXX
HEDERA_PRIVATE_KEY=302e...
HEDERA_NETWORK=testnet

# --- LLM (DeepSeek, OpenAI-compatible) ---
# Optional. Without it the agent runs in deterministic mode (keyword intent +
# raw data, no natural-language summaries). The paid data path still works.
DEEPSEEK_API_KEY=sk-...
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# --- x402 ---
# dev  = full flow runs locally, no real on-chain settlement (default)
# live = direct settlement: the buyer's HashPack wallet submits the HBAR transfer
#        on-chain and the agent verifies it on the mirror node (no facilitator,
#        no treasury private key needed for verification).
X402_MODE=dev

# --- Server ---
PORT=3001
CORS_ORIGIN=http://localhost:3000
